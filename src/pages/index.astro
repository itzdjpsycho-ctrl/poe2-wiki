---
import BaseLayout from '../layouts/BaseLayout.astro';
import KnowledgeCard from '../components/KnowledgeCard.astro';

const base = import.meta.env.BASE_URL;

const knowledgeCards = [
  { slug: 'game_overview',             title: 'Game Overview',          description: 'What POE2 is, how it differs from POE1, and the core game structure.',                            tag: 'Getting Started' },
  { slug: 'classes_and_ascendancies',  title: 'Classes & Ascendancies', description: 'All 8 available classes, ascendancy options, and which are strongest in the current meta.',         tag: 'Character' },
  { slug: 'skills_gems_passives',      title: 'Skills, Gems & Passives',description: 'The 9-socket skill system, spirit gems, passive tree mechanics, and build fundamentals.',            tag: 'Mechanics' },
  { slug: 'defensive_mechanics',       title: 'Defensive Mechanics',    description: 'Life, Armor, Evasion, Energy Shield, Runic Ward, resistances, and the best defensive combos.',      tag: 'Mechanics' },
  { slug: 'endgame_atlas',             title: 'Endgame Atlas',          description: 'Atlas of Worlds, all 7 league mechanics, pinnacle bosses, and ascendancy trials.',                  tag: 'Endgame' },
  { slug: 'currency_crafting_economy', title: 'Currency & Crafting',    description: 'All orbs, Runeforging (Alloys/Verisium), trading systems, and economy tips.',                       tag: 'Economy' },
  { slug: 'current_meta_patch05',      title: 'Current Meta (Patch 0.5)',description: 'Top S-tier builds, what was nerfed/buffed, and the Runes of Aldur league overview.',               tag: 'Meta' },
  { slug: 'campaign_and_bosses',       title: 'Campaign & Bosses',      description: '6-act campaign, act difficulties, boss tips, and notable encounter mechanics.',                     tag: 'Campaign' },
  { slug: 'unique_items_acquisition',  title: 'Unique Item Acquisition',description: 'All unique drop methods, full pinnacle boss loot tables, and the Mageblood farming guide.',         tag: 'Items' },
];

const topBuilds = [
  { name: 'Lightning Arrow', ascendancy: 'Deadeye (Ranger)', note: '#1 — 34%+ of top players' },
  { name: 'Twister',         ascendancy: 'Ranger / Monk',    note: 'Untouched by 0.5 nerfs'   },
  { name: 'Ice Shot',        ascendancy: 'Deadeye (Ranger)', note: 'S-tier single target'      },
  { name: 'Grenade Totems',  ascendancy: 'Warbringer',       note: 'Gold standard starter'     },
];
---

<BaseLayout title="POE2 Expert" description="Path of Exile 2 Expert Reference — Patch 0.5.4 (Return of the Ancients)">

  <!-- Header -->
  <header style="border-bottom: 1px solid rgba(61,45,106,0.4); background: rgba(7,5,15,0.7); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
    <div class="max-w-6xl mx-auto px-6 py-8 flex items-start justify-between gap-4">
      <div>
        <h1 class="font-display text-3xl md:text-4xl mb-2" style="background: linear-gradient(135deg, #a855f7, #c084fc, #e879f9); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          POE2 Expert
        </h1>
        <p class="text-poe-muted text-sm">Path of Exile 2 Reference · Patch 0.5.4 (Return of the Ancients) · Early Access</p>
      </div>
      <a
        href={`${base}search`}
        class="hidden md:flex items-center gap-2 px-4 py-2 rounded-lg text-poe-muted hover:text-poe-gold transition-all text-sm shrink-0"
        style="background: rgba(13,10,30,0.6); border: 1px solid rgba(61,45,106,0.5); backdrop-filter: blur(8px);"
      >
        Search
      </a>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-10 relative z-10">

    <!-- Stats bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      {[
        { value: '0.5.4',  label: 'Current Patch' },
        { value: '31',     label: 'Chase Items'    },
        { value: '27',     label: 'Lineage Gems'   },
        { value: '8',      label: 'Classes'        },
      ].map(({ value, label }) => (
        <div class="card-poe p-4 text-center">
          <div class="font-display text-2xl text-poe-gold-light">{value}</div>
          <div class="text-xs text-poe-muted mt-1">{label}</div>
        </div>
      ))}
    </div>

    <!-- S-Tier builds -->
    <section class="mb-12">
      <div class="card-poe p-6">
        <h2 class="font-display text-poe-gold-light text-lg mb-4">S-Tier Builds — Patch 0.5</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
          {topBuilds.map(b => (
            <div class="rounded-xl p-3 transition-colors"
                 style="background: rgba(7,5,15,0.5); border: 1px solid rgba(61,45,106,0.4);">
              <div class="font-semibold text-poe-text text-sm">{b.name}</div>
              <div class="text-xs text-poe-muted mt-0.5">{b.ascendancy}</div>
              <div class="text-xs text-poe-gold mt-1">{b.note}</div>
            </div>
          ))}
        </div>
        <a href={`${base}knowledge/current_meta_patch05`} class="text-xs text-poe-gold hover:text-poe-gold-light transition-colors">
          View full meta guide →
        </a>
      </div>
    </section>

    <!-- Knowledge Base -->
    <section class="mb-12">
      <h2 class="font-display text-poe-gold-light text-xl mb-6">Knowledge Base</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {knowledgeCards.map(card => (
          <KnowledgeCard
            title={card.title}
            description={card.description}
            href={`${base}knowledge/${card.slug}`}
            tag={card.tag}
          />
        ))}
      </div>
    </section>

    <!-- Item Databases -->
    <section class="mb-12">
      <h2 class="font-display text-poe-gold-light text-xl mb-6">Item Databases</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <KnowledgeCard
          title="Chase Items Browser"
          description="Searchable, filterable database of all 31 chase-tier unique items — filter by slot, tier, and whether they can be chanced."
          href={`${base}chase-items`}
          tag="Database"
        />
        <KnowledgeCard
          title="Lineage Gems Browser"
          description="All 27 chase Lineage Support Gems with stats, prices, boss drop sources, and build synergies — filterable by tier."
          href={`${base}lineage-gems`}
          tag="Database"
        />
      </div>
    </section>
  </main>

  <footer class="relative z-10 py-6 px-6 text-center text-xs text-poe-muted"
          style="border-top: 1px solid rgba(61,45,106,0.4);">
    <p>
      POE2 Expert · Patch 0.5.4 · Stats verified against
      <a href="https://poe2db.tw" class="text-poe-gold hover:text-poe-gold-light" target="_blank" rel="noopener">poe2db.tw</a>
    </p>
    <p class="mt-1">Not affiliated with Grinding Gear Games.</p>
  </footer>
</BaseLayout>
