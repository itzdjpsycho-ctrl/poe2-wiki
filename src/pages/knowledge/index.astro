---
import { getCollection } from 'astro:content';
import KnowledgeLayout from '../../layouts/KnowledgeLayout.astro';
import KnowledgeCard from '../../components/KnowledgeCard.astro';

const base = import.meta.env.BASE_URL;
const entries = await getCollection('knowledge');

// Sort in a logical reading order
const order = [
  'game_overview',
  'classes_and_ascendancies',
  'skills_gems_passives',
  'defensive_mechanics',
  'campaign_and_bosses',
  'endgame_atlas',
  'currency_crafting_economy',
  'current_meta_patch05',
  'unique_items_acquisition',
];

const sorted = [...entries].sort((a, b) => {
  const ai = order.indexOf(a.slug);
  const bi = order.indexOf(b.slug);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});
---

<KnowledgeLayout title="Knowledge Base">
  <h1>Knowledge Base</h1>
  <p class="lead">Complete reference documentation for Path of Exile 2 — Patch 0.5.4 (Return of the Ancients).</p>

  <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
    {sorted.map(entry => (
      <KnowledgeCard
        title={entry.data.name.replace('poe2-', '').replace(/-/g, ' ')}
        description={entry.data.description}
        href={`${base}knowledge/${entry.slug}`}
      />
    ))}
  </div>
</KnowledgeLayout>
