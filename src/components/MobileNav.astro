---
const base = import.meta.env.BASE_URL;

const knowledgeLinks = [
  { slug: 'game_overview',             label: 'Game Overview' },
  { slug: 'classes_and_ascendancies',  label: 'Classes & Ascendancies' },
  { slug: 'skills_gems_passives',      label: 'Skills, Gems & Passives' },
  { slug: 'defensive_mechanics',       label: 'Defensive Mechanics' },
  { slug: 'endgame_atlas',             label: 'Endgame Atlas' },
  { slug: 'currency_crafting_economy', label: 'Currency & Crafting' },
  { slug: 'current_meta_patch05',      label: 'Current Meta (0.5)' },
  { slug: 'campaign_and_bosses',       label: 'Campaign & Bosses' },
  { slug: 'unique_items_acquisition',  label: 'Unique Items' },
];
---

<div>
  <button
    id="mobile-nav-toggle"
    class="p-2 text-poe-muted hover:text-poe-gold transition-colors"
    aria-label="Toggle navigation"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>

  <div id="mobile-nav-overlay" class="hidden fixed inset-0 z-40 bg-black/70"></div>

  <nav id="mobile-nav-drawer" class="hidden fixed top-0 left-0 h-full w-72 z-50 bg-poe-bg border-r border-poe-border overflow-y-auto py-5 px-4">
    <div class="flex items-center justify-between mb-5">
      <a href={base} class="font-display text-poe-gold text-lg">POE2 Expert</a>
      <button id="mobile-nav-close" class="text-poe-muted hover:text-poe-gold p-1 text-xl leading-none">✕</button>
    </div>

    <div class="flex flex-col gap-0.5">
      <a href={base} class="nav-link">Home</a>

      <div class="mt-3">
        <span class="px-3 py-1 text-xs uppercase tracking-widest text-poe-muted font-semibold block mb-1">Knowledge Base</span>
        {knowledgeLinks.map(link => (
          <a href={`${base}knowledge/${link.slug}`} class="nav-link text-sm pl-5">{link.label}</a>
        ))}
      </div>

      <div class="mt-4">
        <span class="px-3 py-1 text-xs uppercase tracking-widest text-poe-muted font-semibold block mb-1">Item Databases</span>
        <a href={`${base}chase-items`} class="nav-link">Chase Items</a>
        <a href={`${base}lineage-gems`} class="nav-link">Lineage Gems</a>
      </div>

      <a href={`${base}search`} class="nav-link mt-4">Search</a>
    </div>

    <div class="mt-8 px-3 py-2 bg-poe-panel border border-poe-border rounded text-xs text-poe-muted">
      Patch 0.5.4 · Early Access
    </div>
  </nav>
</div>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const overlay = document.getElementById('mobile-nav-overlay');
  const drawer = document.getElementById('mobile-nav-drawer');
  const closeBtn = document.getElementById('mobile-nav-close');

  function open() {
    overlay?.classList.remove('hidden');
    drawer?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    overlay?.classList.add('hidden');
    drawer?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', open);
  overlay?.addEventListener('click', close);
  closeBtn?.addEventListener('click', close);

  // Close when clicking any nav link
  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
</script>
