---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;

const path = currentPath.replace(/\/$/, '');

function isActive(href: string) {
  return path === href.replace(/\/$/, '');
}

const knowledgeLinks = [
  { slug: 'game_overview',             label: 'Game Overview' },
  { slug: 'classes_and_ascendancies',  label: 'Classes & Ascendancies' },
  { slug: 'skills_gems_passives',      label: 'Skills, Gems & Passives' },
  { slug: 'defensive_mechanics',       label: 'Defensive Mechanics' },
  { slug: 'endgame_atlas',             label: 'Endgame Atlas' },
  { slug: 'currency_crafting_economy', label: 'Currency & Crafting' },
  { slug: 'current_meta_patch05',      label: 'Current Meta (0.5)' },
  { slug: 'campaign_and_bosses',       label: 'Campaign & Bosses' },
  { slug: 'unique_items_acquisition',  label: 'Unique Items' },
];
---

<nav class="sticky top-0 h-screen overflow-y-auto py-5 px-3 flex flex-col gap-0.5"
     style="background: rgba(7,5,15,0.75); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);">

  <a
    href={base}
    class={`flex items-center gap-2 px-3 py-2.5 rounded-lg font-display text-base mb-4 transition-all duration-200 ${
      isActive(base)
        ? 'text-poe-gold-light'
        : 'text-poe-gold/70 hover:text-poe-gold-light'
    }`}
    style="letter-spacing: 0.04em;"
  >
    <span class="text-poe-gold-light/40 text-lg">⬡</span>
    POE2 Expert
  </a>

  <!-- Knowledge Base -->
  <div>
    <a
      href={`${base}knowledge`}
      class="px-3 py-1 text-xs uppercase tracking-widest text-poe-muted hover:text-poe-gold font-semibold block mb-1 transition-colors"
    >
      Knowledge Base
    </a>
    {knowledgeLinks.map(link => {
      const href = `${base}knowledge/${link.slug}`;
      return (
        <a
          href={href}
          class={`nav-link text-sm pl-5 ${isActive(href) ? 'active' : ''}`}
        >
          {link.label}
        </a>
      );
    })}
  </div>

  <!-- Item Databases -->
  <div class="mt-5">
    <span class="px-3 py-1 text-xs uppercase tracking-widest text-poe-muted font-semibold block mb-1">
      Item Databases
    </span>
    <a href={`${base}chase-items`} class={`nav-link ${isActive(`${base}chase-items`) ? 'active' : ''}`}>
      Chase Items
    </a>
    <a href={`${base}lineage-gems`} class={`nav-link ${isActive(`${base}lineage-gems`) ? 'active' : ''}`}>
      Lineage Gems
    </a>
  </div>

  <!-- Search -->
  <div class="mt-2">
    <a href={`${base}search`} class={`nav-link ${isActive(`${base}search`) ? 'active' : ''}`}>
      Search
    </a>
  </div>

  <!-- Version badge -->
  <div class="mt-auto pt-6">
    <div class="px-3 py-2.5 rounded-xl text-xs text-poe-muted leading-relaxed"
         style="background: rgba(124,58,237,0.08); border: 1px solid rgba(61,45,106,0.5);">
      <span class="text-poe-gold/60 font-semibold">Patch 0.5.4</span><br/>
      <span class="text-poe-muted/70">Early Access</span>
    </div>
  </div>
</nav>
