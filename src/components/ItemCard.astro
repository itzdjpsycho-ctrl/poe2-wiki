---
import RarityBadge from './RarityBadge.astro';

interface Item {
  id: string;
  name: string;
  slot: string;
  base: string;
  levelReq: number;
  canBeChanced: boolean;
  rarityTier: string;
  tags: string[];
  dropSources: string[];
  keyStats: string[];
  whyPowerful: string;
}

interface Props {
  item: Item;
}

const { item } = Astro.props;
---

<article
  class="card-poe p-5"
  data-slot={item.slot.toLowerCase().replace(/ /g, '-')}
  data-tier={item.rarityTier}
  data-chanceable={item.canBeChanced.toString()}
  data-name={item.name.toLowerCase()}
  data-tags={item.tags.join(' ')}
>
  <header class="flex items-start justify-between gap-3 mb-3">
    <h3 class="font-display text-poe-gold text-base leading-tight">{item.name}</h3>
    <RarityBadge tier={item.rarityTier as 'SSS' | 'SS' | 'S' | 'A' | 'B'} />
  </header>

  <div class="flex flex-wrap gap-1.5 mb-3">
    <span class="text-xs text-poe-muted bg-poe-bg px-2 py-0.5 rounded border border-poe-border/60">{item.slot}</span>
    <span class="text-xs text-poe-muted bg-poe-bg px-2 py-0.5 rounded border border-poe-border/60">{item.base}</span>
    <span class="text-xs text-poe-muted bg-poe-bg px-2 py-0.5 rounded border border-poe-border/60">Lvl {item.levelReq}</span>
    {!item.canBeChanced ? (
      <span class="text-xs px-2 py-0.5 rounded border border-red-900/40 text-red-400 bg-red-950/20">No Chance</span>
    ) : (
      <span class="text-xs px-2 py-0.5 rounded border border-green-900/40 text-green-400 bg-green-950/20">Chanceable</span>
    )}
  </div>

  <ul class="space-y-0.5 mb-3">
    {item.keyStats.map(stat => (
      <li class="text-xs text-poe-gold/80 leading-relaxed">{stat}</li>
    ))}
  </ul>

  <details>
    <summary class="text-poe-gold/60 text-xs cursor-pointer hover:text-poe-gold select-none transition-colors">
      Why It's Powerful
    </summary>
    <div class="callout-gold mt-2 text-xs leading-relaxed">
      {item.whyPowerful}
    </div>
  </details>

  <div class="mt-3 pt-3 border-t border-poe-border/40">
    <p class="text-xs text-poe-muted uppercase tracking-wider font-semibold mb-1">Drop Sources</p>
    {item.dropSources.map(source => (
      <p class="text-xs text-poe-text/60 leading-relaxed">{source}</p>
    ))}
  </div>
</article>
