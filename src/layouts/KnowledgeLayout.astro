---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import MobileNav from '../components/MobileNav.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <header class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-poe-border bg-poe-panel sticky top-0 z-30">
    <a href={base} class="font-display text-poe-gold text-lg">POE2 Expert</a>
    <MobileNav />
  </header>

  <div class="flex min-h-screen">
    <aside class="hidden lg:block w-64 shrink-0 border-r border-poe-border">
      <Sidebar currentPath={Astro.url.pathname} />
    </aside>

    <main class="flex-1 min-w-0">
      <div class="max-w-4xl mx-auto px-6 py-10" data-pagefind-body>
        <article class="prose prose-lg prose-poe max-w-none">
          <slot />
        </article>
      </div>
    </main>
  </div>
</BaseLayout>
