---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import MobileNav from '../components/MobileNav.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <header class="lg:hidden flex items-center justify-between px-4 py-3 sticky top-0 z-30"
          style="background: rgba(7,5,15,0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(61,45,106,0.5);">
    <a href={base} class="font-display text-poe-gold-light text-lg tracking-wide">POE2 Expert</a>
    <MobileNav />
  </header>

  <div class="flex min-h-screen">
    <aside class="hidden lg:block w-64 shrink-0 border-r border-poe-border/50 relative z-10">
      <Sidebar currentPath={Astro.url.pathname} />
    </aside>

    <main class="flex-1 min-w-0 px-6 py-8 relative z-10">
      <slot />
    </main>
  </div>
</BaseLayout>
